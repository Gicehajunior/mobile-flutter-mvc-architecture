# App identity
APP_NAME=NestHub Global Limited
APP_ENV=production
APP_VERSION=1.0.0 

# API configuration
API_BASE_URL=http://192.168.100.12:8200/v1
TIMEOUT_SECONDS=30

# Logging and debugging
APP_DEBUG=true
APP_LOGGING=false

# Security settings
API_KEY="your_api_key_here"
API_SECRET="your_api_secret_here"
JWT_SECRET="your_jwt_secret_here"
TOKEN_EXPIRY="3600"