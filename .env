# App identity
APP_NAME="MVC Application"
APP_ENV=production
APP_VERSION=1.0.0 

# API configuration
API_BASE_URL= 'https://127.0.0.1:8000/v1'
TIMEOUT_SECONDS=30

# Logging and debugging
APP_DEBUG=true
APP_LOGGING=true

# Security settings
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
JWT_SECRET=your_jwt_secret_here
TOKEN_EXPIRY=3600